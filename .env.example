# Groq Cloud API Key (Required for Llama-3.3-70b inference engine)
# Generate your free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_actual_groq_api_key_here

# Optional: Application Environment Configuration
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true